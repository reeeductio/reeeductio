{
  "name": "reeeductio",
  "version": "1.0.0",
  "description": "TypeScript SDK for the Reeeductio Spaces API - end-to-end encrypted messaging with capability-based authorization",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:watch": "vitest --config vitest.e2e.config.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "reeeductio",
    "spaces",
    "encrypted",
    "messaging",
    "e2e",
    "end-to-end-encryption",
    "capability-based",
    "authorization"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "@noble/ciphers": "^2.1.1",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
